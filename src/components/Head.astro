---
import type { ComponentProps } from "astro/types";

import Alternate from "./Alternate.astro";
import AppleWebApp from "./AppleWebApp.astro";
import AppLinks from "./AppLinks.astro";
import Archives from "./Archives.astro";
import Assets from "./Assets.astro";
import Base from "./Base.astro";
import Bookmarks from "./Bookmarks.astro";
import Canonical from "./Canonical.astro";
import ColorScheme from "./ColorScheme.astro";
import Description from "./Description.astro";
import Facebook from "./Facebook.astro";
import Manifest from "./Manifest.astro";
import Pinterest from "./Pinterest.astro";
import Robots from "./Robots.astro";
import ThemeColor from "./ThemeColor.astro";
import Title from "./Title.astro";
import Verification from "./Verification.astro";

export type Props = {
	charset?: string;
	viewport?: string;
	base?: ComponentProps<typeof Base>;
	title: ComponentProps<typeof Title>;
	description?: ComponentProps<typeof Description>["value"];
	manifest?: ComponentProps<typeof Manifest>["value"];
	verification?: ComponentProps<typeof Verification>;
	appleWebApp?: ComponentProps<typeof AppleWebApp>;
	canonical?: ComponentProps<typeof Canonical>["href"];
	alternate?: ComponentProps<typeof Alternate>;
	appLinks?: ComponentProps<typeof AppLinks>;
	archives?: ComponentProps<typeof Archives>["value"];
	assets?: ComponentProps<typeof Assets>["value"];
	bookmarks?: ComponentProps<typeof Bookmarks>["value"];
	facebook?: ComponentProps<typeof Facebook>;
	pinterest?: ComponentProps<typeof Pinterest>["richPin"];
	robots?: ComponentProps<typeof Robots>;
	themeColor?: ComponentProps<typeof ThemeColor>["value"];
	colorScheme?: ComponentProps<typeof ColorScheme>["value"];
};

const {
	charset = "utf-8",
	viewport = "width=device-width, initial-scale=1.0",
	base,
	title,
	description,
	manifest,
	verification,
	appleWebApp,
	canonical,
	alternate,
	appLinks,
	archives,
	assets,
	bookmarks,
	facebook,
	pinterest,
	robots,
	themeColor,
	colorScheme,
} = Astro.props;
---

<head>
	<meta charset={charset} />
	<meta name="viewport" content={viewport} />
	{base && <Base {...base} />}
	<Title {...title} />
	<slot />
	{description && <Description value={description} />}
	{manifest && <Manifest value={manifest} />}
	{verification && <Verification {...verification} />}
	{appleWebApp && <AppleWebApp {...appleWebApp} />}
	<Canonical href={canonical} />
	{alternate && <Alternate {...alternate} />}
	{appLinks && <AppLinks {...appLinks} />}
	{archives && <Archives value={archives} />}
	{assets && <Assets value={assets} />}
	{bookmarks && <Bookmarks value={bookmarks} />}
	{facebook && <Facebook {...facebook} />}
	{pinterest !== undefined && <Pinterest richPin={pinterest} />}
	{robots && <Robots {...robots} />}
	{themeColor && <ThemeColor value={themeColor} />}
	{colorScheme && <ColorScheme value={colorScheme} />}
</head>

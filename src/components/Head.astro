---
import type { ComponentProps } from "astro/types";

import Title from "@/components/Title.astro";
import Description from "@/components/Description.astro";
import Base from "@/components/Base.astro";

export type Props = {
	charset?: string;
	viewport?: string;
	base?: ComponentProps<typeof Base>;
	title: ComponentProps<typeof Title>;
	description?: ComponentProps<typeof Description>;
};

const { charset = "utf-8", viewport = "width=device-width, initial-scale=1.0", base, title, description } = Astro.props;
---

<head>
	<meta charset={charset} />
	<meta name="viewport" content={viewport} />
	{base && <Base {...base} />}
	<Title {...title} />
	<slot />
	{description && <Description {...description} />}
</head>

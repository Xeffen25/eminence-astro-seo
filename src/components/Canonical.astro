---
export type Props = {
	href?: string | URL | false;
};

const { href } = Astro.props;

const canonicalHref =
	href === false
		? false
		: href === undefined
			? Astro.site
				? new URL(Astro.url.pathname, Astro.site).toString()
				: undefined
			: typeof href === "string"
				? href
				: href.toString();
---

{canonicalHref && <link rel="canonical" href={canonicalHref} />}

{
	"printWidth": 120,
	"tabWidth": 4,
	"useTabs": true,
	"plugins": ["prettier-plugin-organize-imports", "prettier-plugin-astro"],
	"overrides": [
		{
			"files": "*.md",
			"options": {
				"parser": "markdown",
				"plugins": []
			}
		},
		{
			"files": "*.astro",
			"options": {
				"parser": "astro"
			}
		}
	]
}
